---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Contact from '../components/Contact.astro';
import { about, competencies, openSource, education } from '../data/site';
---

<BaseLayout>
  <Hero />

  <!-- About -->
  <section id="about" class="section">
    <div class="container">
      <p class="eyebrow reveal">// 01 — about</p>
      <div class="about-grid">
        <h2 class="statement reveal">
          I own the full path from <span class="accent">scrape</span> to
          <span class="accent">ETL</span> to <span class="accent">delivery</span> —
          and keep it running in production.
        </h2>
        <div class="about-body reveal" data-delay="100">
          {about.map((p) => <p>{p}</p>)}
          <ul class="competencies">
            {competencies.map((c) => <li class="chip">{c}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <Experience />
  <Projects />
  <Skills />

  <!-- Open source + education -->
  <section id="opensource" class="section">
    <div class="container">
      <div class="os-grid">
        <div class="card os-lead reveal">
          <p class="eyebrow">// 05 — open source</p>
          <h3 class="os-h">Contributor to <span class="accent">scrapy/scrapy</span></h3>
          <p class="os-p">{openSource[0].desc} Public scraping projects &amp; utilities live on GitHub.</p>
          <div class="edu">
            <span class="edu-k">education</span>
            <span class="edu-v">{education.degree} · {education.place}</span>
          </div>
        </div>

        <div class="os-links">
          <a class="card link-card reveal" href="https://github.com/kevalsakhiya" target="_blank" rel="noopener" data-delay="60">
            <div>
              <div class="lc-k">github</div>
              <div class="lc-v">github.com/kevalsakhiya</div>
            </div>
            <span class="lc-arrow">↗</span>
          </a>
          <a class="card link-card reveal" href="https://www.linkedin.com/in/kevalsakhiya" target="_blank" rel="noopener" data-delay="120">
            <div>
              <div class="lc-k">linkedin</div>
              <div class="lc-v">linkedin.com/in/kevalsakhiya</div>
            </div>
            <span class="lc-arrow">↗</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Contact />
</BaseLayout>

<style>
  .accent { color: var(--accent); }

  .about-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: clamp(2rem, 5vw, 4rem); align-items: start; margin-top: 1.25rem; }
  .statement { font-size: clamp(1.55rem, 3.4vw, 2.5rem); font-weight: 500; line-height: 1.25; letter-spacing: -0.02em; }
  .about-body { display: grid; gap: 1.1rem; }
  .about-body p { color: var(--text-soft); font-size: 1.02rem; line-height: 1.7; }
  .competencies { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }

  .os-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; align-items: stretch; }
  .os-lead { padding: clamp(1.75rem, 3vw, 2.5rem); }
  .os-h { font-size: clamp(1.35rem, 2.6vw, 1.85rem); font-weight: 600; letter-spacing: -0.02em; margin-top: 1.1rem; }
  .os-p { color: var(--text-soft); margin-top: 0.75rem; font-size: 0.97rem; line-height: 1.65; max-width: 52ch; }
  .edu { display: flex; flex-direction: column; gap: 0.2rem; margin-top: 1.6rem; padding-top: 1.4rem; border-top: 1px solid var(--border); }
  .edu-k { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent-ink); text-transform: uppercase; letter-spacing: 0.1em; }
  .edu-v { color: var(--text-soft); font-size: 0.95rem; }

  .os-links { display: flex; flex-direction: column; gap: 1rem; }
  .link-card { flex: 1; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.5rem 1.6rem; }
  .link-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .lc-k { font-family: var(--font-mono); font-size: 0.74rem; color: var(--text-faint); margin-bottom: 0.3rem; }
  .lc-v { font-size: 1.05rem; font-weight: 600; }
  .lc-arrow { font-family: var(--font-mono); font-size: 1.25rem; color: var(--accent); }
</style>

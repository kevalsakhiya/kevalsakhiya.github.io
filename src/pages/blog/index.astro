---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Blog" description="Notes on web scraping, distributed crawling, anti-bot, and data engineering.">
  <section class="section">
    <div class="container">
      <p class="eyebrow reveal">// blog</p>
      <h1 class="section-title reveal" style="margin-bottom:0.9rem">Notes from the crawl</h1>
      <p class="intro reveal">Field notes and war stories on running scrapers in production — scale, anti-bot, data quality, monitoring, and AI.</p>

      {posts.length === 0 ? (
        <p class="empty reveal"><span class="mono">$</span> ls ~/blog → <span class="faint">no posts yet — first one's brewing.</span></p>
      ) : (
        <ul class="posts">
          {posts.map((post, i) => (
            <li class="reveal" data-delay={(i % 2) * 70}>
              <a class="card post" href={`/blog/${post.id}/`}>
                <div class="p-meta">
                  <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
                  {post.data.tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
                </div>
                <h2 class="p-title">{post.data.title}</h2>
                <p class="p-desc">{post.data.description}</p>
                <span class="read">read <span class="mono">→</span></span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .intro { color: var(--text-soft); margin-bottom: clamp(2.25rem, 5vh, 3.5rem); }
  .empty { font-family: var(--font-mono); color: var(--text-soft); }
  .empty .faint { color: var(--text-faint); }
  .mono { font-family: var(--font-mono); color: var(--accent); }

  .posts { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .post { display: flex; flex-direction: column; height: 100%; padding: clamp(1.5rem, 3vw, 2rem); }
  .post:hover { transform: translateY(-3px); border-color: var(--accent); }
  @media (max-width: 720px) { .posts { grid-template-columns: 1fr; } }

  .p-meta { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; font-family: var(--font-mono); font-size: 0.74rem; color: var(--text-faint); }
  .tag {
    color: var(--accent-ink); padding: 0.2rem 0.55rem;
    border: 1px solid color-mix(in oklab, var(--accent) 40%, var(--border2)); border-radius: 99px;
  }
  .p-title { font-size: clamp(1.25rem, 3vw, 1.6rem); font-weight: 600; margin-top: 0.85rem; }
  .p-desc { color: var(--text-soft); margin-top: 0.6rem; font-size: 0.97rem; line-height: 1.6; }
  .read { margin-top: auto; padding-top: 1.1rem; font-family: var(--font-mono); color: var(--accent-ink); font-size: 0.85rem; }
  .read .mono { color: inherit; }
</style>

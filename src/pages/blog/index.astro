---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Blog" description="Notes on web scraping, distributed crawling, anti-bot, and data engineering.">
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">Writing</p>
        <h2 class="section-title">Notes from the crawl</h2>
        <p>Field notes on distributed scraping, anti-bot, data quality, and pipelines.</p>
      </div>

      {posts.length === 0 ? (
        <p class="empty">No posts yet — first one's brewing.</p>
      ) : (
        <ul class="posts">
          {posts.map((post) => (
            <li class="reveal">
              <a class="card post" href={`/blog/${post.id}/`}>
                <div class="p-meta">
                  <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
                  {post.data.tags.slice(0, 2).map((t) => <span class="chip">{t}</span>)}
                </div>
                <h3 class="p-title">{post.data.title}</h3>
                <p class="p-desc">{post.data.description}</p>
                <span class="read">Read post →</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .empty { color: var(--text-faint); }
  .posts { display: grid; gap: 1.25rem; }
  .post { display: block; padding: 1.75rem; }
  .post:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); border-color: color-mix(in srgb, var(--accent) 35%, var(--border)); }
  .p-meta { display: flex; align-items: center; gap: 0.7rem; flex-wrap: wrap; color: var(--text-faint); font-size: 0.85rem; font-family: var(--font-mono); }
  .p-title { font-size: 1.4rem; margin-top: 0.8rem; }
  .p-desc { color: var(--text-soft); margin-top: 0.6rem; }
  .read { display: inline-block; margin-top: 1.1rem; color: var(--accent-ink); font-weight: 500; font-size: 0.95rem; }
</style>

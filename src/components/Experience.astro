---
import { experience } from '../data/site';
---

<section id="experience" class="section">
  <div class="container">
    <p class="eyebrow reveal">// 02 — experience</p>
    <h2 class="section-title reveal" style="margin-bottom:clamp(2.25rem,5vh,3.5rem)">Where I've shipped</h2>

    <div class="rows">
      {experience.map((job, i) => (
        <div class={`row reveal${i === experience.length - 1 ? ' last' : ''}`}>
          <div class="meta-col">
            <div class="period">{job.period}</div>
            <h3 class="company">{job.company}</h3>
            <div class="role">{job.role}</div>
            <div class="loc">{job.meta}</div>
          </div>
          <ul class="points">
            {job.points.map((p) => (
              <li><span class="mark">▹</span><span set:html={p} /></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .rows { display: flex; flex-direction: column; }
  .row {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: clamp(1.25rem, 4vw, 3rem);
    border-top: 1px solid var(--border); padding: clamp(1.75rem, 4vh, 2.5rem) 0;
  }
  .row.last { border-bottom: 1px solid var(--border); }

  .period { font-family: var(--font-mono); font-size: 0.78rem; color: var(--accent-ink); margin-bottom: 0.65rem; }
  .company { font-size: 1.45rem; font-weight: 600; }
  .role { color: var(--text-soft); margin-top: 0.35rem; font-size: 0.95rem; }
  .loc { font-family: var(--font-mono); font-size: 0.74rem; color: var(--text-faint); margin-top: 0.4rem; }

  .points { display: flex; flex-direction: column; gap: 0.85rem; }
  .points li { display: flex; gap: 0.7rem; color: var(--text-soft); font-size: 0.96rem; line-height: 1.55; }
  .mark { color: var(--accent); font-family: var(--font-mono); flex-shrink: 0; }
  .points :global(span) { color: inherit; }
  .points :global(.mark + span span) { color: var(--text); }
</style>

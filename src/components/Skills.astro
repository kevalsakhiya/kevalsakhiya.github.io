---
import Icon from './Icon.astro';
import { skills, languages } from '../data/site';

// Languages lead the toolchain as the first cell.
const groups = [{ group: 'Languages', icon: 'code', items: languages }, ...skills];
---

<section id="skills" class="section">
  <div class="container">
    <p class="eyebrow reveal">// 04 — technical skills</p>
    <h2 class="section-title reveal" style="margin-bottom:clamp(2.25rem,5vh,3.5rem)">The toolchain</h2>

    <div class="grid reveal">
      {groups.map((g) => (
        <div class="cell">
          <div class="g-head">
            <Icon name={g.icon} size={16} class="g-ico" />
            <span class="g-title">{g.group}</span>
          </div>
          <ul class="items">
            {g.items.map((i, idx) => (
              <li class={idx === 0 ? 'lead' : ''}>{i}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px;
    background: var(--border); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;
  }
  .cell { padding: clamp(1.4rem, 2.6vw, 1.9rem); background: var(--bg2); }
  .g-head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; color: var(--accent-ink); }
  .g-ico { flex-shrink: 0; }
  .g-title {
    font-family: var(--font-mono); font-size: 0.74rem;
    text-transform: uppercase; letter-spacing: 0.1em;
  }
  .items { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .items li {
    font-size: 0.86rem; color: var(--text-soft);
    padding: 0.38rem 0.7rem; border: 1px solid var(--border2); border-radius: 8px; background: var(--surface);
  }
  .items li.lead { color: var(--text); }
</style>

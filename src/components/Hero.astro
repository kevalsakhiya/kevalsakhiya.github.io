---
import Icon from './Icon.astro';
import { site, socials, stats } from '../data/site';
---

<section class="hero" id="top">
  <div class="container grid">
    <div class="copy reveal">
      <span class="tag"><span class="tag-dot"></span>{site.title}</span>
      <h1>
        I build systems that<br />
        <span class="accent">harvest the web</span><br />
        at scale.
      </h1>
      <p class="lead">{site.tagline}</p>

      <div class="cta">
        <a class="btn btn-primary" href="/#projects">
          View key projects <span class="mono-arrow">→</span>
        </a>
        <a class="btn btn-ghost" href={site.resume} target="_blank" rel="noopener">
          Download resume <Icon name="download" size={16} />
        </a>
      </div>

      <ul class="socials">
        {socials.map((s) => (
          <li>
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} title={s.label}>
              <Icon name={s.icon} size={18} />
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Terminal card -->
    <div class="term-wrap reveal" data-delay="120">
      <div class="term-glow" aria-hidden="true"></div>
      <div class="term">
        <div class="term-bar">
          <span class="tdot red"></span>
          <span class="tdot yellow"></span>
          <span class="tdot green"></span>
          <span class="term-title">keval@pipeline: ~</span>
        </div>
        <pre class="term-body"><span class="p">$</span> keval --whoami
<span class="f">&#123;</span>
  <span class="k">"role"</span>: <span class="s">"Web Scraping Specialist"</span>,
  <span class="k">"focus"</span>: [<span class="s">"distributed crawling"</span>, <span class="s">"anti-bot"</span>],
  <span class="k">"stack"</span>: [<span class="s">"Scrapy"</span>, <span class="s">"Airflow"</span>, <span class="s">"PySpark"</span>],
  <span class="k">"open_source"</span>: <span class="s">"scrapy/scrapy"</span>,
  <span class="k">"location"</span>: <span class="s">"Anand, India"</span>,
  <span class="k">"status"</span>: <span class="s">"available"</span>
<span class="f">&#125;</span>
<span class="p">$</span> <span class="cursor"></span></pre>
      </div>
    </div>
  </div>

  <div class="container">
    <ul class="stats reveal" data-delay="180">
      {stats.map((s) => (
        <li>
          <span class={`num${s.accent ? ' is-accent' : ''}`}>
            <span data-count={s.count} data-format={s.format} data-suffix={s.suffix}>0</span>
          </span>
          <span class="lbl">{s.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero { padding-top: clamp(7rem, 18vh, 11rem); padding-bottom: clamp(2.5rem, 6vh, 4.5rem); }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(330px, 1fr)); gap: clamp(2.25rem, 5vw, 4.5rem); align-items: center; }

  .tag {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--accent-ink); padding: 0.4rem 0.75rem; border: 1px solid var(--border2);
    border-radius: 99px; background: var(--surface); margin-bottom: 1.5rem;
  }
  .tag-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }

  h1 { font-size: clamp(2.5rem, 7vw, 4.75rem); line-height: 0.98; font-weight: 600; letter-spacing: -0.035em; }
  .accent { color: var(--accent); }
  .lead { color: var(--text-soft); font-size: clamp(1rem, 1.7vw, 1.2rem); margin-top: 1.6rem; max-width: 46ch; line-height: 1.6; }

  .cta { display: flex; gap: 0.8rem; margin-top: 2.1rem; flex-wrap: wrap; }
  .mono-arrow { font-family: var(--font-mono); }

  .socials { display: flex; gap: 0.5rem; margin-top: 2rem; }
  .socials a {
    display: grid; place-items: center; width: 2.75rem; height: 2.75rem;
    border-radius: 9px; border: 1px solid var(--border2); color: var(--text-soft);
    background: var(--surface); transition: color 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
  }
  .socials a:hover { color: var(--accent-ink); border-color: var(--accent); transform: translateY(-2px); }

  /* Terminal card — always dark, in both themes */
  .term-wrap { position: relative; }
  .term-glow {
    position: absolute; inset: -1px; border-radius: 15px;
    background: linear-gradient(150deg, color-mix(in oklab, var(--accent) 40%, transparent), transparent 55%);
    filter: blur(2px); opacity: 0.5;
  }
  .term {
    position: relative; border: 1px solid #2c3038; border-radius: 14px;
    background: linear-gradient(180deg, #0d0f13, #0a0b0e); overflow: hidden;
    box-shadow: 0 30px 70px -30px rgba(0, 0, 0, 0.8);
  }
  .term-bar {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.8rem 1rem; border-bottom: 1px solid #23262d; background: #0e1014;
  }
  .tdot { width: 11px; height: 11px; border-radius: 50%; }
  .tdot.red { background: #ff5f57; }
  .tdot.yellow { background: #febc2e; }
  .tdot.green { background: #28c840; }
  .term-title { margin-left: 0.6rem; font-family: var(--font-mono); font-size: 0.75rem; color: #646a73; }
  .term-body {
    margin: 0; padding: 1.4rem 1.25rem; font-family: var(--font-mono);
    font-size: clamp(0.72rem, 1.5vw, 0.84rem); line-height: 1.95; color: #9aa0aa; white-space: pre-wrap;
  }
  .term-body .p { color: #4ade80; }
  .term-body .f { color: #646a73; }
  .term-body .k { color: #7dd3fc; }
  .term-body .s { color: #4ade80; }
  .cursor {
    display: inline-block; width: 9px; height: 1.05em; background: #4ade80;
    vertical-align: text-bottom; animation: termBlink 1.05s step-end infinite;
  }
  @keyframes termBlink { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .cursor { animation: none; } }

  /* Stat strip */
  .stats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
    margin-top: clamp(3rem, 7vh, 5rem);
    background: var(--border); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;
  }
  .stats li { background: var(--bg2); padding: 1.6rem 1.4rem; }
  .num { display: block; font-size: clamp(1.85rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.03em; }
  .num.is-accent { color: var(--accent); }
  .lbl {
    display: block; font-family: var(--font-mono); font-size: 0.8rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-faint); margin-top: 0.45rem;
  }

  @media (max-width: 820px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>

---
import { site, socials } from '../data/site';

const contactLinks = socials.filter((s) => s.icon !== 'mail');
---

<section id="contact" class="section">
  <div class="container">
    <div class="panel reveal">
      <div class="panel-glow" aria-hidden="true"></div>
      <div class="inner">
        <p class="eyebrow">// 06 — contact</p>
        <h2 class="title">Got data that needs harvesting?</h2>
        <p class="blurb">
          I'm available for web-scraping &amp; data-engineering work. Let's scope your pipeline.
        </p>
        <a class="btn btn-primary email" href={`mailto:${site.email}`}>
          <span class="mono">$</span> {site.email}
        </a>
        <div class="links">
          {contactLinks.map((s, i) => (
            <>
              {i > 0 && <span class="dot">·</span>}
              <a href={s.href} target="_blank" rel="noopener">{s.label.toLowerCase()}</a>
            </>
          ))}
          <span class="dot">·</span>
          <span class="loc">{site.location}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .panel {
    position: relative; overflow: hidden;
    border: 1px solid var(--border2); border-radius: 24px;
    background: linear-gradient(160deg, var(--surface), var(--bg2));
    padding: clamp(2.5rem, 7vw, 5.25rem) clamp(1.5rem, 5vw, 4rem); text-align: center;
  }
  .panel-glow {
    position: absolute; top: -40%; left: 50%; transform: translateX(-50%);
    width: 700px; height: 520px; pointer-events: none;
    background: radial-gradient(circle, color-mix(in oklab, var(--accent) 20%, transparent), transparent 60%);
    filter: blur(30px);
  }
  .inner { position: relative; }
  .title { font-size: clamp(1.9rem, 5.4vw, 3.6rem); font-weight: 600; letter-spacing: -0.03em; line-height: 1.05; max-width: 16ch; margin: 1.25rem auto 0; }
  .blurb { color: var(--text-soft); margin: 1.1rem auto 2.1rem; max-width: 48ch; font-size: 1.05rem; }
  .email { font-size: 1rem; }
  .email .mono { font-family: var(--font-mono); }

  .links {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: clamp(0.8rem, 3vw, 2rem); margin-top: 2.1rem;
    font-family: var(--font-mono); font-size: 0.84rem; color: var(--text-soft);
  }
  .links a { transition: color 0.18s ease; }
  .links a:hover { color: var(--text); }
  .dot { color: var(--border2); }
  .loc { color: var(--text-faint); }
</style>
